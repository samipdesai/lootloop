default_platform(:ios)

# LootLoop iOS lanes (M7). Auth is via the App Store Connect API key (no Apple
# ID / 2FA), read from APP_STORE_CONNECT_* env (repo-root .env.local locally,
# GitHub secrets in CI). Signing (match) + the TestFlight build lane land in #59.
platform :ios do
  # App Store Connect API key, shared by every lane that talks to Apple.
  # set_spaceship_token makes Spaceship-based actions (produce, deliver, pilot)
  # authenticate with this key automatically — they don't take an api_key param.
  def asc_key
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("LOOTLOOP_ASC_KEY_PATH"),
      set_spaceship_token: true,
    )
  end

  # Upload native dSYMs to Sentry so crash reports symbolicate (#61). Runs AFTER
  # gym and is BOTH gated (skips without SENTRY_AUTH_TOKEN) and non-fatal (a
  # failed upload never fails an otherwise-good TestFlight build). sentry-cli is
  # a transitive dep of @sentry/react-native, resolved relative to it. The JS
  # bundle already carries Debug IDs (metro withSentryConfig); wiring JS
  # source-map auto-upload into the Xcode bundle phase is a separate follow-up
  # that needs a real release build to verify, so it's intentionally not here.
  def upload_dsyms_to_sentry
    unless ENV["SENTRY_AUTH_TOKEN"]
      UI.important("SENTRY_AUTH_TOKEN unset — skipping Sentry dSYM upload.")
      return
    end
    dsym = lane_context[SharedValues::DSYM_OUTPUT_PATH]
    unless dsym && File.exist?(dsym)
      UI.important("No dSYM from gym — skipping Sentry dSYM upload.")
      return
    end
    cli = sh("node", "-e",
             "const p=require('path');" \
             "console.log(require.resolve('@sentry/cli/bin/sentry-cli'," \
             "{paths:[p.dirname(require.resolve('@sentry/react-native/package.json'))]}))",
             log: false).strip
    begin
      sh("node", cli, "debug-files", "upload", "--include-sources",
         "--org", "lootloopus", "--project", "lootloop-ios", dsym)
      UI.success("✓ Uploaded dSYMs to Sentry (lootloop-ios)")
    rescue => e
      UI.error("Sentry dSYM upload failed (non-fatal): #{e}")
    end
  end

  # Register the App ID / bundle id in the Developer portal via the API key
  # (idempotent). The App Store Connect *app record* can't be created by the API
  # — that's done once in the ASC UI (selecting this bundle id). See #57.
  desc "Push App Store text metadata — description, keywords, categories, URLs (#58)"
  lane :metadata do
    deliver(
      api_key: asc_key,
      app_version: "1.0",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true, # no interactive HTML preview
      run_precheck_before_submit: false,
    )
  end

  desc "Create/sync the App Store distribution cert + profile via match (#59)"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: "com.lootloop.mobile",
      api_key: asc_key,
      readonly: false,
    )
  end

  desc "Build a signed Release .ipa and upload to TestFlight (#59)"
  lane :beta do
    # Release builds talk to PRODUCTION Supabase. react-native-config picks the
    # env file from ENVFILE at build time; default .env is LOCAL (dev/Maestro).
    ENV["ENVFILE"] = File.expand_path("../../.env.production", __dir__)
    key = asc_key
    # Pull the App Store signing cert + profile (read-only — created by `certs`).
    match(type: "appstore", app_identifier: "com.lootloop.mobile", api_key: key, readonly: true)
    # Next build number = latest on TestFlight + 1 (0 for the very first upload).
    next_build = latest_testflight_build_number(
      api_key: key, app_identifier: "com.lootloop.mobile", initial_build_number: 0,
    ) + 1
    # Apply the build number AND the match distribution signing at build time via
    # xcargs — so the committed project is untouched: Info.plist keeps its
    # $(CURRENT_PROJECT_VERSION) reference, and Debug/simulator dev stays on
    # automatic signing. Only this archive uses the manual App Store profile.
    gym(
      workspace: "mobile.xcworkspace",
      scheme: "mobile",
      export_method: "app-store",
      clean: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build} " \
              "DEVELOPMENT_TEAM=WF7D7TB3W8 CODE_SIGN_STYLE=Manual " \
              'PROVISIONING_PROFILE_SPECIFIER="match AppStore com.lootloop.mobile" ' \
              'CODE_SIGN_IDENTITY="Apple Distribution"',
    )
    upload_dsyms_to_sentry
    pilot(api_key: key, skip_waiting_for_build_processing: true)
  end

  desc "List the App Store Connect app records (#57 verify)"
  lane :list_apps do
    asc_key
    apps = Spaceship::ConnectAPI::App.all
    UI.important("#{apps.count} app record(s):")
    apps.each { |a| UI.message("  #{a.name}  [#{a.bundle_id}]  id=#{a.id}") }
  end

  desc "List all bundle ids registered to this account (#57 diagnosis)"
  lane :list_bundle_ids do
    asc_key
    ids = Spaceship::ConnectAPI::BundleId.all(limit: 200)
    UI.important("#{ids.count} bundle id(s) in this account:")
    ids.each { |b| UI.message("  #{b.identifier}  (#{b.name})") }
  end

  desc "Register the com.lootloop.mobile bundle id (#57)"
  lane :register_bundle_id do
    asc_key # sets Spaceship::ConnectAPI.token
    identifier = "com.lootloop.mobile"
    existing = Spaceship::ConnectAPI::BundleId.all(limit: 200).detect { |b| b.identifier == identifier }
    if existing
      UI.success("✓ Bundle ID already registered: #{identifier} (#{existing.name})")
    else
      Spaceship::ConnectAPI::BundleId.create(name: "LootLoop", identifier: identifier, platform: "IOS")
      UI.success("✓ Registered bundle ID: #{identifier}")
    end
  end
end
